# ===========================================
# ErrorWatch Self-Hosted Caddyfile
# ===========================================
# Public ACME certificates are provisioned automatically for:
#   - https://{$DOMAIN}
#   - https://api.{$DOMAIN}
#
# Keep ports 80/443 publicly reachable for ACME issuance and renewal.

{
    admin off
    email {$ACME_EMAIL}
    log {
        output stdout
        format json
    }
}

{$DOMAIN} {
    encode gzip zstd

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }

    reverse_proxy {$DASHBOARD_UPSTREAM:web:3000}
}

api.{$DOMAIN} {
    @sse {
        path /sse/*
    }

    # SSE streams are sensitive to proxy/content-encoding transforms.
    handle @sse {
        reverse_proxy {$API_UPSTREAM:api:3333} {
            header_up Accept-Encoding identity
            flush_interval -1
            transport http {
                compression off
                versions 1.1
            }
        }
    }

    handle {
        encode gzip zstd

        header {
            Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
            X-Frame-Options "DENY"
            X-Content-Type-Options "nosniff"
            Referrer-Policy "strict-origin-when-cross-origin"
            -Server
        }

        reverse_proxy {$API_UPSTREAM:api:3333}
    }
}
