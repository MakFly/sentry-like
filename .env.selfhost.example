# ===========================================
# ErrorWatch Self-Hosted Configuration
# ===========================================
# Copy this file to .env and fill in all required values.
# Generate secrets with: openssl rand -base64 32

# --- Domain & URLs ---
# Your domain name (e.g., errorwatch.example.com)
DOMAIN=errorwatch.example.com
ACME_EMAIL=admin@example.com

# Public URLs (must match your domain + DNS setup)
DASHBOARD_URL=https://errorwatch.example.com
API_URL=https://api.errorwatch.example.com
BETTER_AUTH_URL=https://api.errorwatch.example.com
NEXT_PUBLIC_APP_URL=https://errorwatch.example.com
NEXT_PUBLIC_MONITORING_API_URL=https://api.errorwatch.example.com

# --- Database ---
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_24
# POSTGRES_DB=errorwatch
# POSTGRES_USER=errorwatch

# --- Security (required) ---
BETTER_AUTH_SECRET=CHANGE_ME_USE_openssl_rand_base64_32
ADMIN_API_KEY=ew_admin_CHANGE_ME
API_KEY_HASH_SECRET=CHANGE_ME_USE_openssl_rand_base64_32

# --- Image version (optional, defaults to latest) ---
# ERRORWATCH_VERSION=latest

# --- OAuth (optional) ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- Email via Resend (optional) ---
# RESEND_API_KEY=
# EMAIL_FROM=noreply@example.com

# --- Stripe (optional) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_TEAM=
# STRIPE_PRICE_ENTERPRISE=

# --- Advanced ---
# LOG_LEVEL=info
# DATABASE_POOL_SIZE=20
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
