# ===========================================
# ErrorWatch Self-Hosted Configuration
# ===========================================
#
# 1. Copy this file to .env:        cp .env.selfhost.example .env
# 2. Generate all secrets at once:   see commands below
# 3. Edit DOMAIN / URLs to match your DNS
# 4. Start:                          ./run-selfhost.sh install
#
# ──────────────────────────────────
#  GENERATE ALL SECRETS (run once)
# ──────────────────────────────────
#
#   openssl rand -base64 32   → use for BETTER_AUTH_SECRET, API_KEY_HASH_SECRET
#   openssl rand -base64 24   → use for POSTGRES_PASSWORD
#   openssl rand -hex 20      → use for ADMIN_API_KEY (prefix with ew_admin_)
#
# Quick one-liner to generate everything:
#
#   echo "POSTGRES_PASSWORD=$(openssl rand -base64 24)"
#   echo "BETTER_AUTH_SECRET=$(openssl rand -base64 32)"
#   echo "API_KEY_HASH_SECRET=$(openssl rand -base64 32)"
#   echo "ADMIN_API_KEY=ew_admin_$(openssl rand -hex 20)"
#
# ⚠️  Once deployed, NEVER change BETTER_AUTH_SECRET or API_KEY_HASH_SECRET
#     — it would invalidate all existing sessions and API keys.
#     POSTGRES_PASSWORD can only be changed by also resetting the database.

# ===========================================
# DOMAIN & URLs (required)
# ===========================================
# DNS: create two A records pointing to your VPS IP:
#   errorwatch.example.com     → <VPS_IP>
#   api.errorwatch.example.com → <VPS_IP>
# Caddy auto-provisions a public HTTPS certificate.
# Keep ports 80/443 publicly reachable for ACME and Chrome-trusted TLS.
# Do not IP-allowlist 80/443 in this standard self-host mode.

DOMAIN=errorwatch.example.com
ACME_EMAIL=admin@example.com

DASHBOARD_URL=https://errorwatch.example.com
API_URL=https://api.errorwatch.example.com
BETTER_AUTH_URL=https://api.errorwatch.example.com

# ===========================================
# DATABASE (required)
# ===========================================
# Generate: openssl rand -base64 24

POSTGRES_PASSWORD=CHANGE_ME
# POSTGRES_DB=errorwatch
# POSTGRES_USER=errorwatch

# ===========================================
# SECRETS (required)
# ===========================================
# Generate each: openssl rand -base64 32
# ⚠️  Do not change after first deployment.

BETTER_AUTH_SECRET=CHANGE_ME
API_KEY_HASH_SECRET=CHANGE_ME
USE_SECURE_COOKIES=true

# Generate: ew_admin_$(openssl rand -hex 20)
# This key is used for server-to-server calls (web → api).
ADMIN_API_KEY=ew_admin_CHANGE_ME

# ===========================================
# IMAGE VERSION (optional)
# ===========================================
# Pin a specific release or use "latest" (default).
# ERRORWATCH_VERSION=0.5.0

# ===========================================
# EMAIL (optional — needed for invitations)
# ===========================================
# Resend: https://resend.com → API Keys
# Without this, invitation emails won't be sent (invite links still work via dashboard).
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=ErrorWatch <noreply@errorwatch.example.com>

# ===========================================
# STRIPE (optional — needed for billing)
# ===========================================
# Without these, all users get unlimited access (no paywall).
# STRIPE_SECRET_KEY=sk_live_xxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxx
# STRIPE_PRICE_PRO=price_xxxx
# STRIPE_PRICE_TEAM=price_xxxx
# STRIPE_PRICE_ENTERPRISE=price_xxxx

# ===========================================
# ADVANCED (optional)
# ===========================================
# Already hardcoded to "true" in docker-compose.selfhost.yml.
# Only override if using docker-compose.prod.yml for self-hosting.
# SELF_HOSTED=true

# If true, authenticated users pass through even if the API is temporarily down.
# AUTH_FAIL_OPEN=false

# Set to false to hide SSO buttons and disable OAuth providers.
# NEXT_PUBLIC_ENABLE_SSO=true

# LOG_LEVEL=info
# DATABASE_POOL_SIZE=20
# DATABASE_SSL=false
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
