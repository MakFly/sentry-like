# ===========================================
# ErrorWatch Production Environment
# ===========================================
# Copy this file to project root as .env.production
# cp deploy/.env.production.example .env.production

NODE_ENV=production
PORT=3333
LOG_LEVEL=info

# Public URLs
DOMAIN=errorwatch.io
ACME_EMAIL=admin@errorwatch.io
DASHBOARD_URL=https://errorwatch.io
API_URL=https://api.errorwatch.io
BETTER_AUTH_URL=https://api.errorwatch.io

# Caddy (Docker)
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
DASHBOARD_UPSTREAM=web:3000
API_UPSTREAM=api:3333

# PostgreSQL (Docker internal)
POSTGRES_DB=errorwatch
POSTGRES_USER=errorwatch
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://errorwatch:CHANGE_ME@postgres:5432/errorwatch
DATABASE_POOL_SIZE=20
DATABASE_SSL=false

# Redis (Docker internal)
REDIS_URL=redis://redis:6379

# Security secrets
BETTER_AUTH_SECRET=CHANGE_ME
ADMIN_API_KEY=ew_admin_CHANGE_ME
API_KEY_HASH_SECRET=CHANGE_ME
USE_SECURE_COOKIES=true

# Optional auth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_ENABLE_SSO=true

# Email
RESEND_API_KEY=
EMAIL_FROM=ErrorWatch <alerts@errorwatch.io>

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_ENTERPRISE=

# Optional behavior toggles
AUTH_FAIL_OPEN=false
SUBSCRIPTION_BYPASS_EMAILS=

# Self-hosted mode: gives all users enterprise access (no Stripe needed)
SELF_HOSTED=true
