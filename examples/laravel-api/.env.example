APP_NAME="ErrorWatch Laravel Example"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# -------------------------------------------------------------------
# ErrorWatch SDK configuration
# -------------------------------------------------------------------
ERRORWATCH_ENABLED=true
ERRORWATCH_ENDPOINT=http://localhost:3333
ERRORWATCH_API_KEY=your-project-api-key
ERRORWATCH_LOG_LEVEL=debug
ERRORWATCH_LOGGING_ENABLED=true
